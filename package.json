{
  "name": "clayportal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/check-runtime.js",
    "dev": "NEXT_DIST_DIR=.next-dev next dev",
    "prebuild": "node scripts/check-runtime.js && rm -rf .next .next-build .next-dev",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "prestart": "node scripts/check-runtime.js",
    "start": "node .next-build/standalone/server.js",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "db:seed": "knex seed:run",
    "bootstrap:admin": "node scripts/bootstrap-platform-admin.js"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.0.1",
    "clsx": "^2.1.1",
    "firebase": "^10.14.1",
    "firebase-admin": "^13.6.0",
    "jose": "^5.9.4",
    "knex": "^3.1.0",
    "next": "^14.2.33",
    "nodemailer": "^6.10.0",
    "pg": "^8.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.33",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "typescript": "^5.7.2"
  }
}
